#lang racket
(require redex)

(define-language peg-solitaire
  (position ::= тЦИ тЧЛ тЧП)
  (board ::= ([position ...] ...)))

(module+ test
  (test-equal (redex-match? peg-solitaire board (term ([тЦИ])))
              #t)
  (test-equal (redex-match? peg-solitaire board (term ([тЦИ тЧП]
                                                       [тЧЛ тЦИ])))
              #t)
  (test-equal (redex-match? peg-solitaire board (term ([тЦИ тЦИ]
                                                       [тЦИ тЧП тЧП])))
              #t))

(define-term initial-board
  ([тЦИ тЦИ тЧП тЧП тЧП тЦИ тЦИ]
   [тЦИ тЦИ тЧП тЧП тЧП тЦИ тЦИ]
   [тЧП тЧП тЧП тЧП тЧП тЧП тЧП]
   [тЧП тЧП тЧП тЧЛ тЧП тЧП тЧП]
   [тЧП тЧП тЧП тЧП тЧП тЧП тЧП]
   [тЦИ тЦИ тЧП тЧП тЧП тЦИ тЦИ]
   [тЦИ тЦИ тЧП тЧП тЧП тЦИ тЦИ]))

(define move
  (reduction-relation
   peg-solitaire
   #:domain board
   (--> (any_1
         ...
         [any_2 ... тЧП тЧП тЧЛ any_3 ...]
         any_4
         ...)
        (any_1
         ...
         [any_2 ... тЧЛ тЧЛ тЧП any_3 ...]
         any_4
         ...)
        тЖТ)
   (--> (any_1
         ...
         [any_2 ... тЧЛ тЧП тЧП any_3 ...]
         any_4
         ...)
        (any_1
         ...
         [any_2 ... тЧП тЧЛ тЧЛ any_3 ...]
         any_4
         ...)
        тЖР)
   (--> (any_1
         ...
         [any_2 ..._1 тЧП any_3 ...]
         [any_4 ..._1 тЧП any_5 ...]
         [any_6 ..._1 тЧЛ any_7 ...]
         any_8
         ...)
        (any_1
         ...
         [any_2 ... тЧЛ any_3 ...]
         [any_4 ... тЧЛ any_5 ...]
         [any_6 ... тЧП any_7 ...]
         any_8
         ...)
        тЖУ)
   (--> (any_1
         ...
         [any_2 ..._1 тЧЛ any_3 ...]
         [any_4 ..._1 тЧП any_5 ...]
         [any_6 ..._1 тЧП any_7 ...]
         any_8
         ...)
        (any_1
         ...
         [any_2 ... тЧП any_3 ...]
         [any_4 ... тЧЛ any_5 ...]
         [any_6 ... тЧЛ any_7 ...]
         any_8
         ...)
        тЖС)))

(module+ test
  (test-equal (apply-reduction-relation move (term initial-board))
              '(((тЦИ тЦИ тЧП тЧП тЧП тЦИ тЦИ)
                 (тЦИ тЦИ тЧП тЧП тЧП тЦИ тЦИ)
                 (тЧП тЧП тЧП тЧП тЧП тЧП тЧП)
                 (тЧП тЧП тЧП тЧП тЧП тЧП тЧП)
                 (тЧП тЧП тЧП тЧЛ тЧП тЧП тЧП)
                 (тЦИ тЦИ тЧП тЧЛ тЧП тЦИ тЦИ)
                 (тЦИ тЦИ тЧП тЧП тЧП тЦИ тЦИ))
                ((тЦИ тЦИ тЧП тЧП тЧП тЦИ тЦИ)
                 (тЦИ тЦИ тЧП тЧЛ тЧП тЦИ тЦИ)
                 (тЧП тЧП тЧП тЧЛ тЧП тЧП тЧП)
                 (тЧП тЧП тЧП тЧП тЧП тЧП тЧП)
                 (тЧП тЧП тЧП тЧП тЧП тЧП тЧП)
                 (тЦИ тЦИ тЧП тЧП тЧП тЦИ тЦИ)
                 (тЦИ тЦИ тЧП тЧП тЧП тЦИ тЦИ))
                ((тЦИ тЦИ тЧП тЧП тЧП тЦИ тЦИ)
                 (тЦИ тЦИ тЧП тЧП тЧП тЦИ тЦИ)
                 (тЧП тЧП тЧП тЧП тЧП тЧП тЧП)
                 (тЧП тЧП тЧП тЧП тЧЛ тЧЛ тЧП)
                 (тЧП тЧП тЧП тЧП тЧП тЧП тЧП)
                 (тЦИ тЦИ тЧП тЧП тЧП тЦИ тЦИ)
                 (тЦИ тЦИ тЧП тЧП тЧП тЦИ тЦИ))
                ((тЦИ тЦИ тЧП тЧП тЧП тЦИ тЦИ)
                 (тЦИ тЦИ тЧП тЧП тЧП тЦИ тЦИ)
                 (тЧП тЧП тЧП тЧП тЧП тЧП тЧП)
                 (тЧП тЧЛ тЧЛ тЧП тЧП тЧП тЧП)
                 (тЧП тЧП тЧП тЧП тЧП тЧП тЧП)
                 (тЦИ тЦИ тЧП тЧП тЧП тЦИ тЦИ)
                 (тЦИ тЦИ тЧП тЧП тЧП тЦИ тЦИ))))

  #;
  (traces move (term initial-board))

  #;
  (stepper move (term initial-board)))