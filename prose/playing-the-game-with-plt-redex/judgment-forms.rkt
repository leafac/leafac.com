(define-judgment-form peg-solitaire
  #:mode (тЖТ* I O)
  #:contract (тЖТ* board board)

  [---------------- "Reflexivity"
   (тЖТ* board board)]

  [(тЖТ  board_1 board_2)
   (тЖТ* board_2 board_3)
   -------------------- "Transitivity"
   (тЖТ* board_1 board_3)])

