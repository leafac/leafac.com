#lang racket
(require redex)
(provide example-board-1 example-board-2 initial-board example-winning-board)

(test-equal (term 0)
            0)
(test-equal (term "a")
            "a")
(test-equal (term a)
            'a)
(test-equal (term тЧП)
            'тЧП)
(test-equal (term тЧЛ)
            'тЧЛ)
(test-equal (term (тЧП тЧП тЧЛ))
            '(тЧП тЧП тЧЛ))

(define-term a-peg тЧП)
(test-equal (term a-peg)
            'тЧП)

(define-term example-board-1
  ([┬╖ ┬╖ тЧП тЧП тЧП ┬╖ ┬╖]
   [┬╖ ┬╖ тЧП тЧП тЧЛ ┬╖ ┬╖]
   [тЧП тЧЛ тЧП тЧЛ тЧП тЧП тЧП]
   [тЧП тЧП тЧП тЧЛ тЧЛ тЧЛ тЧП]
   [тЧП тЧЛ тЧП тЧП тЧП тЧП тЧП]
   [┬╖ ┬╖ тЧП тЧЛ тЧП ┬╖ ┬╖]
   [┬╖ ┬╖ тЧП тЧП тЧП ┬╖ ┬╖]))

(define-term example-board-2
  ([┬╖ ┬╖ тЧП тЧЛ тЧП ┬╖ ┬╖]
   [┬╖ ┬╖ тЧП тЧП тЧЛ ┬╖ ┬╖]
   [тЧП тЧЛ тЧП тЧЛ тЧП тЧП тЧП]
   [тЧП тЧП тЧП тЧЛ тЧЛ тЧЛ тЧП]
   [тЧП тЧЛ тЧП тЧП тЧЛ тЧП тЧП]
   [┬╖ ┬╖ тЧП тЧЛ тЧП ┬╖ ┬╖]
   [┬╖ ┬╖ тЧЛ тЧП тЧП ┬╖ ┬╖]))

(define-term initial-board
  ([┬╖ ┬╖ тЧП тЧП тЧП ┬╖ ┬╖]
   [┬╖ ┬╖ тЧП тЧП тЧП ┬╖ ┬╖]
   [тЧП тЧП тЧП тЧП тЧП тЧП тЧП]
   [тЧП тЧП тЧП тЧЛ тЧП тЧП тЧП]
   [тЧП тЧП тЧП тЧП тЧП тЧП тЧП]
   [┬╖ ┬╖ тЧП тЧП тЧП ┬╖ ┬╖]
   [┬╖ ┬╖ тЧП тЧП тЧП ┬╖ ┬╖]))

(define-term example-winning-board
  ([┬╖ ┬╖ тЧЛ тЧЛ тЧЛ ┬╖ ┬╖]
   [┬╖ ┬╖ тЧЛ тЧЛ тЧЛ ┬╖ ┬╖]
   [тЧЛ тЧЛ тЧЛ тЧЛ тЧЛ тЧЛ тЧЛ]
   [тЧЛ тЧЛ тЧЛ тЧП тЧЛ тЧЛ тЧЛ]
   [тЧЛ тЧЛ тЧЛ тЧЛ тЧЛ тЧЛ тЧЛ]
   [┬╖ ┬╖ тЧЛ тЧЛ тЧЛ ┬╖ ┬╖]
   [┬╖ ┬╖ тЧЛ тЧЛ тЧЛ ┬╖ ┬╖]))
